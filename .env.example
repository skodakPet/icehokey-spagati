# Zkopíruj tento soubor jako .env.local (pro lokální vývoj přes `vercel dev`)
# Pro produkci nastav stejné hodnoty ve Vercel → Project Settings → Environment Variables

# Connection string z Neon (Console → Connection Details → "Pooled connection")
# SERVER-ONLY — NIKDY ho nedávej do VITE_* prefixu, jinak skončí v bundle!
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Token pro Vercel Blob (Storage → Blob store → .env.local snippet ho vygeneruje)
# Server-only.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
